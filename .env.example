DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
POSTGRES_DB=ligilo
POSTGRES_USER=ligilo
POSTGRES_PASSWORD=ligilo
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://ligilo:ligilo@db:5432/ligilo

# Supabase PostgreSQL (Pooler)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=change-me
# Example:
# DATABASE_URL=postgresql+psycopg://postgres.your-project-ref:change-me@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Safe from Harm / media metadata pipeline
SAFE_FROM_HARM_TERMS=violencia,abuso,autolesion,bomba,arma,matar,odio,acoso
MEDIA_TRANSCRIPT_EXCERPT_LIMIT=280

# Telegram bot webhook
TELEGRAM_BOT_TOKEN=change-me
